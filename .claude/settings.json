{
  "permissions": {
    "allow": [
      "Bash(jq:*)",
      "Bash(git checkout:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh repo view:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(oc get:*)",
      "Bash(oc describe:*)",
      "Bash(find . :*)",
      "Bash(find ./:*)"
    ]
  },
  "model": "claude-opus-4-6",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "safety-net@cc-marketplace": true,
    "ops@aro-plugins": true
  },
  "extraKnownMarketplaces": {
    "cc-marketplace": {
      "source": {
        "source": "github",
        "repo": "kenryu42/cc-marketplace"
      },
      "autoUpdate": true
    },
    "aro-plugins": {
      "source": {
        "source": "directory",
        "path": "~/aro/plugins"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "api.github.com",
        "github.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/go/",
        "~/.cache/go-build/",
        "~/work/claude"
      ],
      "denyRead": [
        "~/.ssh/**",
        "~/.config/gcloud/**"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "showClearContextOnPlanAccept": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754057532483
  }
}
